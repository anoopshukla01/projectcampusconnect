{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* JavaScript support — this is a .jsx project */
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",

    /* Path aliases — keep in sync with vite.config.js */
    "baseUrl": ".",
    "paths": {
      "@/*":          ["src/*"],
      "@ctx/*":       ["src/context/*"],
      "@placement/*": ["../placementDashboard/*"],
      "@admin/*":     ["../adminDashboard/*"],
      "@professor/*": ["../professorDashboard/*"]
    },

    /* Linting — relaxed for JS project, IDE won't flood red */
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "strict": false
  },
  "include": ["src", "../placementDashboard", "../adminDashboard", "../professorDashboard"]
}
