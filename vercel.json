{
  "framework": "vite",
  "installCommand": "npm --prefix campus-connect-react install",
  "buildCommand": "npm --prefix campus-connect-react run build",
  "outputDirectory": "campus-connect-react/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://campusconnect-backend.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
