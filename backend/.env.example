# ─────────────────────────────────────────────────────────────────────────────
# StudentSphere Backend — Environment Variables
#
# SETUP:
#   cp .env.example .env
#   Fill in all CHANGE_ME values.
#   .env is excluded from git — NEVER commit it.
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_64

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be DIFFERENT from SECRET_KEY.
JWT_SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_64

# ── Supabase Credentials ──────────────────────────────────────────────────────
SUPABASE_KEY=CHANGE_ME_publishable_api_key

# ── Database (Supabase PostgreSQL) ────────────────────────────────────────────
#
# WHERE TO FIND THESE:
#   Supabase Dashboard → Project → Settings → Database → Connection String
#
# PRODUCTION — use the Connection Pooler (Transaction mode, port 6543):
#   This is the correct URL for a running Flask server behind pgBouncer.
#   Avoids hitting Supabase's direct connection limit under load.
#   Format: postgresql://postgres.[project-ref]:[db-password]@aws-0-[region].pooler.supabase.com:6543/postgres
#
#   Example:
#   DATABASE_URL=postgresql://postgres.abcdefghijklmnop:your_db_password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
#
DATABASE_URL=CHANGE_ME_supabase_pooler_url_port_6543

# DEVELOPMENT (optional) — use the Direct Connection (port 5432):
#   Use this for local dev only if you want to connect directly to Supabase.
#   Or leave as sqlite:///studentsphere_dev.db for fully offline dev.
#   Format: postgresql://postgres.[project-ref]:[db-password]@db.[project-ref].supabase.co:5432/postgres
#
#   Example:
#   DATABASE_URL=postgresql://postgres.abcdefghijklmnop:your_db_password@db.abcdefghijklmnop.supabase.co:5432/postgres
#
# TESTING — stays as SQLite in-memory (do NOT point tests at your real DB):
TEST_DATABASE_URL=sqlite:///:memory:

# ── Redis (rate limiting + JWT blocklist) ────────────────────────────────────
# In production: use Upstash Redis (free tier, works with Supabase stacks).
# Get URL from: https://console.upstash.com → Database → REST URL (use Redis URL, not REST)
# Format: redis://default:<password>@<host>:<port>
#
# In development, an in-memory fallback is used automatically (no Redis needed).
REDIS_URL=CHANGE_ME_redis_url

# ── College settings ──────────────────────────────────────────────────────────
# Faculty registration email must end with this domain (e.g. @srmist.edu.in).
ALLOWED_EMAIL_DOMAIN=college.edu.in
COLLEGE_NAME=My College Name

# ── CORS (production) ─────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins. No trailing slash.
# Example: https://studentsphere.vercel.app,https://app.mycollege.edu.in
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── OTP / SMS provider ────────────────────────────────────────────────────────
# Set MOCK_OTP=true in development — OTP will be logged to console.
# Set MOCK_OTP=false in production and configure SMS_API_KEY below.
MOCK_OTP=true
SMS_PROVIDER=fast2sms       # options: fast2sms | msg91 | twilio
SMS_API_KEY=CHANGE_ME

# ── Email (faculty approval notifications) ────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=noreply@college.edu.in
MAIL_PASSWORD=CHANGE_ME
MAIL_DEFAULT_SENDER=StudentSphere <noreply@college.edu.in>

# ── Security tuning ───────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
INVITE_EXPIRY_HOURS=48
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30
DATA_RETENTION_YEARS=3

# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE QUICK-START CHECKLIST
# ─────────────────────────────────────────────────────────────────────────────
# 1. Create project at https://supabase.com/dashboard
# 2. Go to Settings → Database → Connection Pooler → Transaction mode (port 6543)
# 3. Copy the connection string and paste as DATABASE_URL above
# 4. Run migrations: flask db upgrade
# 5. NEVER use the Supabase Auth system — we use our own JWT flow
# 6. NEVER enable Row Level Security (RLS) for tables managed by this app —
#    our RBAC is enforced at the application layer (Flask blueprints)
# ─────────────────────────────────────────────────────────────────────────────
