# ─────────────────────────────────────────────────────────────────────────────
# StudentSphere Backend — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets & credentials — NEVER commit these ───────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
lib/
lib64/
wheels/
.installed.cfg
MANIFEST

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/

# ── Testing & coverage ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover

# ── SQLite dev databases ─────────────────────────────────────────────────────
*.db
*.sqlite3
*.sqlite

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Alembic ──────────────────────────────────────────────────────────────────
# Keep alembic/versions tracked — migrations are code.
# Do NOT add alembic/versions here.
